        <li>
          <p>Berbuka dengan Kurma atau Air Putih,</p>
        </li>
        <li>
          <p>Berdoa Ketika Berbuka,</p>
        </li>
        <li>
          <p>Banyak Bersedekah,</p>
        </li>
        <li>
          <p>Memperlihatkan Akhlak yang Baik,</p>
        </li>
        <li>
          <p>Banyak membaca Alquran,</p>
        </li>
        <li>
          <p>Shalat Tarawih,</p>
        </li>
        <li>
          <p>Melaksanakan I’tikaf,</p>
        </li>
      </ul>
    </div>
